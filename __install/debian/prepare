export ACME_EMAIL_ACCOUNT="" # Provived to ssl.com for SSL certificates sign defaulted to ADMIN_EMAIL

# DO NOT CHANGE below this line
export DRUMEE_REPO=app.drumee.com
export INFRA_COMPONENTS=all
